<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1280.0" spacing="25.0" style="-fx-background-color: #F8F9FA;"
      stylesheets="@../../css/styles.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.startupledgerpro.controller.ProjectDetailsController">

    <padding>
        <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Button onAction="#handleBackToDashboard" styleClass="button-secondary" text="⬅️ Back to Dashboard" />
                <VBox HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="projectNameLabel" style="-fx-text-fill: #1C1F21; -fx-font-size: 24px; -fx-font-weight: bold;" text="Project Workspace Detail" />
                        <Label fx:id="projectCategoryLabel" style="-fx-text-fill: #848D95; -fx-font-size: 13px;" text="Engineering Track Core Operations" />
                    </children>
                </VBox>
                <Button styleClass="button-primary" text="➕ Assign New Task" onAction="#handleAddTask"/>
                <Button styleClass="button-danger" text="🚪 Log Out" onAction="#handleLogout"/>
            </children>
        </HBox>

        <HBox spacing="20.0">
            <children>
                <VBox prefWidth="250.0" spacing="8.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-border-radius: 12px;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /></padding>
                    <children>
                        <Label style="-fx-text-fill: #848D95; -fx-font-size: 12px; -fx-font-weight: bold;" text="ALLOCATED FUNDING" />
                        <Label fx:id="projectBudgetLabel" style="-fx-text-fill: #1C1F21; -fx-font-size: 20px; -fx-font-weight: bold;" text="Tk 0.00" />
                    </children>
                </VBox>

                <VBox prefWidth="250.0" spacing="8.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-border-radius: 12px;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /></padding>
                    <children>
                        <Label style="-fx-text-fill: #848D95; -fx-font-size: 12px; -fx-font-weight: bold;" text="LIFECYCLE STATUS" />
                        <Label fx:id="projectStatusLabel" style="-fx-text-fill: #00B37E; -fx-font-size: 18px; -fx-font-weight: bold;" text="UNKNOWN" />
                    </children>
                </VBox>

                <VBox spacing="8.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-border-radius: 12px;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /></padding>
                    <children>
                        <Label style="-fx-text-fill: #848D95; -fx-font-size: 12px; -fx-font-weight: bold;" text="PROJECT TARGET SCOPE BRIEF" />
                        <Label fx:id="projectDescriptionLabel" style="-fx-text-fill: #1C1F21; -fx-font-size: 13px;" text="No structural core description assigned." wrapText="true" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <VBox spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-padding: 20px;" VBox.vgrow="ALWAYS">
            <children>
                <Label style="-fx-text-fill: #1C1F21; -fx-font-size: 16px; -fx-font-weight: bold;" text="Task Requirements Board" />

                <TableView fx:id="tasksTableView" styleClass="light-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTaskTitle" prefWidth="250.0" text="Task Requirement Title" />
                        <TableColumn fx:id="colAssignee" prefWidth="200.0" text="Assigned Engineer ID" />
                        <TableColumn fx:id="colTaskStatus" prefWidth="150.0" text="Execution State" />
                        <TableColumn fx:id="colDueDate" prefWidth="150.0" text="Target Due Date" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>