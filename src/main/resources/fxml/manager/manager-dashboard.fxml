<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="800.0" prefWidth="1280.0" style="-fx-background-color: #F4F6F8;"
      stylesheets="@../../css/styles.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.startupledgerpro.controller.ManagerDashboardController">

    <VBox prefWidth="260.0" spacing="25.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E9EB; -fx-border-width: 0 1 0 0;">
        <padding>
            <Insets bottom="30.0" left="24.0" right="24.0" top="30.0" />
        </padding>
        <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <children>
                    <VBox alignment="CENTER" prefHeight="36.0" prefWidth="36.0" style="-fx-background-color: #E6F7F2; -fx-background-radius: 8px;">
                        <children>
                            <Label style="-fx-text-fill: #00B37E; -fx-font-weight: bold; -fx-font-size: 14px;" text="SL" />
                        </children>
                    </VBox>
                    <VBox>
                        <children>
                            <Label style="-fx-text-fill: #1C1F21; -fx-font-size: 15px; -fx-font-weight: bold;" text="StartupLedger" />
                            <Label style="-fx-text-fill: #848D95; -fx-font-size: 11px;" text="Manager Panel" />
                        </children>
                    </VBox>
                </children>
            </HBox>

            <Label style="-fx-text-fill: #848D95; -fx-font-size: 11px; -fx-font-weight: bold;" text="MAIN MENU" />

            <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                <children>
                    <Button maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="button-sidebar-active" text="📊 Dashboard" onAction="#handleShowDashboardOverview" />
                    <Button maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="button-sidebar" text="👷 Engineer Directory" onAction="#handleShowEngineerDirectory" />
                    <Button maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="button-sidebar" text="📂 All Projects" onAction="#handleShowProjectsOverview" />
                    <Button maxWidth="Infinity" alignment="BASELINE_LEFT" styleClass="button-sidebar" text="📈 Analytics" onAction="#handleShowAnalytics" />
                </children>
            </VBox>

            <Button maxWidth="Infinity" styleClass="button-danger" text="Sign Out" onAction="#handleLogout"/>
        </children>
    </VBox>

    <VBox spacing="30.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #F8F9FA;">
        <padding>
            <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
        </padding>
        <children>

            <HBox alignment="CENTER_LEFT">
                <children>
                    <VBox HBox.hgrow="ALWAYS">
                        <children>
                            <Label style="-fx-text-fill: #1C1F21; -fx-font-size: 22px; -fx-font-weight: bold;" text="Dashboard Overview" />
                            <Label fx:id="welcomeLabel" style="-fx-text-fill: #848D95; -fx-font-size: 13px;" text="Welcome back, Manager" />
                        </children>
                    </VBox>
                    <HBox spacing="10">
                        <Button styleClass="btn-outline" text="🧾 Record Expense" onAction="#handleRecordExpense"/>
                        <Button styleClass="button-primary" text="➕ Create New Project" onAction="#handleCreateProject"/>
                    </HBox>
                </children>
            </HBox>

            <HBox spacing="20.0" maxWidth="Infinity">
                <children>
                    <VBox prefWidth="220.0" spacing="12.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-border-radius: 12px;" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <children>
                            <HBox alignment="TOP_RIGHT"><Label style="-fx-text-fill: #00B37E; -fx-font-size: 11px; -fx-background-color: #E6F7F2; -fx-background-radius: 4px; -fx-padding: 2 6 2 6;" text="↑ Active Now" /></HBox>
                            <Label fx:id="engineerCountLabel" style="-fx-text-fill: #1C1F21; -fx-font-size: 28px; -fx-font-weight: bold;" text="8" />
                            <Label style="-fx-text-fill: #848D95; -fx-font-size: 13px;" text="Assigned Engineers" />
                        </children>
                    </VBox>

                    <VBox prefWidth="220.0" spacing="12.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-border-radius: 12px;" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <children>
                            <HBox alignment="TOP_RIGHT"><Label style="-fx-text-fill: #00B37E; -fx-font-size: 11px; -fx-background-color: #E6F7F2; -fx-background-radius: 4px; -fx-padding: 2 6 2 6;" text="↑ 3 this month" /></HBox>
                            <Label fx:id="activeProjectCountLabel" style="-fx-text-fill: #1C1F21; -fx-font-size: 28px; -fx-font-weight: bold;" text="5" />
                            <Label style="-fx-text-fill: #848D95; -fx-font-size: 13px;" text="Active Tracked Projects" />
                        </children>
                    </VBox>

                    <VBox prefWidth="220.0" spacing="12.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-border-radius: 12px;" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <children>
                            <HBox alignment="TOP_RIGHT"><Label style="-fx-text-fill: #00B37E; -fx-font-size: 11px; -fx-background-color: #E6F7F2; -fx-background-radius: 4px; -fx-padding: 2 6 2 6;" text="18% vs last month" /></HBox>
                            <Label fx:id="budgetTotalLabel" style="-fx-text-fill: #1C1F21; -fx-font-size: 28px; -fx-font-weight: bold;" text="Tk 2,80,000" />
                            <Label style="-fx-text-fill: #848D95; -fx-font-size: 13px;" text="Total Project Budget" />
                        </children>
                    </VBox>

                    <VBox prefWidth="220.0" spacing="12.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-border-radius: 12px;" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <children>
                            <HBox alignment="TOP_RIGHT"><Label fx:id="financialHealthLabel" style="-fx-text-fill: #00B37E; -fx-font-size: 11px; -fx-background-color: #E6F7F2; -fx-background-radius: 4px; -fx-padding: 2 6 2 6;" text="Healthy balance" /></HBox>
                            <Label fx:id="remainingBalanceLabel" style="-fx-text-fill: #1C1F21; -fx-font-size: 28px; -fx-font-weight: bold;" text="Tk 0.00" />
                            <Label style="-fx-text-fill: #848D95; -fx-font-size: 13px;" text="Remaining Balance" />
                        </children>
                    </VBox>

                    <VBox prefWidth="220.0" spacing="12.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-border-radius: 12px;" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <children>
                            <HBox alignment="TOP_RIGHT"><Label style="-fx-text-fill: #F75A68; -fx-font-size: 11px; -fx-background-color: #FEECEF; -fx-background-radius: 4px; -fx-padding: 2 6 2 6;" text="↓ 5 unresolved" /></HBox>
                            <Label fx:id="pendingTasksCountLabel" style="-fx-text-fill: #1C1F21; -fx-font-size: 28px; -fx-font-weight: bold;" text="14" />
                            <Label style="-fx-text-fill: #848D95; -fx-font-size: 13px;" text="Pending Tasks" />
                        </children>
                    </VBox>
                </children>
            </HBox>

            <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                <children>

                    <VBox spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-padding: 20px;" HBox.hgrow="ALWAYS">
                        <children>
                            <Label style="-fx-text-fill: #1C1F21; -fx-font-size: 16px; -fx-font-weight: bold;" text="Active Project Assignments" />
                            <TableView fx:id="projectTableView" styleClass="light-table" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colProjectName" prefWidth="200.0" text="Project Title" />
                                    <TableColumn fx:id="colEngineer" prefWidth="150.0" text="Lead Engineer" />
                                    <TableColumn fx:id="colProgress" prefWidth="120.0" text="Status" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </children>
                    </VBox>

                    <VBox prefWidth="520.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E5E9EB; -fx-padding: 20px;">
                        <children>
                            <HBox alignment="CENTER_LEFT">
                                <children>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label style="-fx-text-fill: #1C1F21; -fx-font-size: 16px; -fx-font-weight: bold;" text="Scrum Board" />
                                            <Label fx:id="scrumStatusLabel" style="-fx-text-fill: #475569; -fx-font-size: 12px;" text="Tasks grouped by workflow state" />
                                            <Label fx:id="scrumProjectLabel" style="-fx-text-fill: #64748B; -fx-font-size: 11px;" text="Filter: All projects" />
                                        </children>
                                    </VBox>
                                    <Button styleClass="btn-outline" text="Refresh" onAction="#handleRefreshScrumBoard" />
                                    <Button styleClass="button-primary" text="See Board" onAction="#handleOpenBoardView" />
                                </children>
                            </HBox>
                            <HBox spacing="16.0" VBox.vgrow="ALWAYS">
                                <children>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10px; -fx-border-color: #E5E9EB; -fx-border-radius: 10px; -fx-padding: 18px;">
                                        <children>
                                            <Label style="-fx-text-fill: #64748B; -fx-font-size: 11px; -fx-font-weight: bold;" text="TO DO" />
                                            <Label fx:id="todoCountLabel" style="-fx-text-fill: #475569; -fx-font-size: 11px;" text="0 tasks" />
                                            <VBox fx:id="todoColumn" spacing="14.0" VBox.vgrow="ALWAYS" style="-fx-padding: 6 0 0 0;" HBox.hgrow="ALWAYS" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10px; -fx-border-color: #E5E9EB; -fx-border-radius: 10px; -fx-padding: 18px;">
                                        <children>
                                            <Label style="-fx-text-fill: #2563EB; -fx-font-size: 11px; -fx-font-weight: bold;" text="IN PROGRESS" />
                                            <Label fx:id="inProgressCountLabel" style="-fx-text-fill: #475569; -fx-font-size: 11px;" text="0 tasks" />
                                            <VBox fx:id="inProgressColumn" spacing="14.0" VBox.vgrow="ALWAYS" style="-fx-padding: 6 0 0 0;" HBox.hgrow="ALWAYS" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10px; -fx-border-color: #E5E9EB; -fx-border-radius: 10px; -fx-padding: 18px;">
                                        <children>
                                            <Label style="-fx-text-fill: #15803D; -fx-font-size: 11px; -fx-font-weight: bold;" text="DONE" />
                                            <Label fx:id="doneCountLabel" style="-fx-text-fill: #475569; -fx-font-size: 11px;" text="0 tasks" />
                                            <VBox fx:id="doneColumn" spacing="14.0" VBox.vgrow="ALWAYS" style="-fx-padding: 6 0 0 0;" HBox.hgrow="ALWAYS" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                </children>
            </HBox>

        </children>
    </VBox>
</HBox>
