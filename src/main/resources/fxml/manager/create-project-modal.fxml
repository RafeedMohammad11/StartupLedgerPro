<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox prefWidth="480.0" spacing="0"
      style="-fx-background-color: #FFFFFF;"
      stylesheets="@../../css/styles.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.startupledgerpro.controller.CreateProjectModalController">

    <padding>
        <Insets bottom="32" left="32" right="32" top="32"/>
    </padding>

    <!-- Header -->
    <VBox spacing="4">
        <Label text="Create New Project"
               style="-fx-text-fill: #18181B;
                      -fx-font-size: 18px;
                      -fx-font-weight: bold;"/>
        <Label text="Fill in the details below to initialise a new project workspace."
               style="-fx-text-fill: #71717A; -fx-font-size: 12px;"/>
        <VBox.margin><Insets bottom="20"/></VBox.margin>
    </VBox>

    <Separator style="-fx-background-color: #E4E4E7;">
        <VBox.margin><Insets bottom="24"/></VBox.margin>
    </Separator>

    <!-- Form fields -->
    <VBox spacing="18">

        <!-- Project Name -->
        <VBox spacing="6">
            <Label text="Project Name *"
                   style="-fx-text-fill: #3F3F46;
                          -fx-font-size: 13px;
                          -fx-font-weight: bold;"/>
            <TextField fx:id="nameField"
                       promptText="e.g. E-Commerce Platform"
                       style="-fx-background-color: #FAFAFA;
                              -fx-border-color: #E4E4E7;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;
                              -fx-font-size: 13px;
                              -fx-text-fill: #18181B;"/>
        </VBox>

        <!-- Category -->
        <VBox spacing="6">
            <Label text="Category *"
                   style="-fx-text-fill: #3F3F46;
                          -fx-font-size: 13px;
                          -fx-font-weight: bold;"/>
            <ComboBox fx:id="categoryComboBox"
                      maxWidth="Infinity"
                      promptText="Select a project category..."
                      style="-fx-background-color: #FAFAFA;
                             -fx-border-color: #E4E4E7;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-font-size: 13px;"/>
        </VBox>

        <!-- Budget + Deadline row -->
        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Budget (Tk) *"
                       style="-fx-text-fill: #3F3F46;
                              -fx-font-size: 13px;
                              -fx-font-weight: bold;"/>
                <TextField fx:id="budgetField"
                           promptText="e.g. 250000"
                           style="-fx-background-color: #FAFAFA;
                                  -fx-border-color: #E4E4E7;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 10 14;
                                  -fx-font-size: 13px;
                                  -fx-text-fill: #18181B;"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Deadline * (YYYY-MM-DD)"
                       style="-fx-text-fill: #3F3F46;
                              -fx-font-size: 13px;
                              -fx-font-weight: bold;"/>
                <TextField fx:id="deadlineField"
                           promptText="e.g. 2026-12-31"
                           style="-fx-background-color: #FAFAFA;
                                  -fx-border-color: #E4E4E7;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 10 14;
                                  -fx-font-size: 13px;
                                  -fx-text-fill: #18181B;"/>
            </VBox>
        </HBox>

        <!-- Description -->
        <VBox spacing="6">
            <Label text="Description"
                   style="-fx-text-fill: #3F3F46;
                          -fx-font-size: 13px;
                          -fx-font-weight: bold;"/>
            <TextArea fx:id="descriptionArea"
                      prefRowCount="3"
                      promptText="Briefly describe the project goals and scope..."
                      wrapText="true"
                      style="-fx-background-color: #FAFAFA;
                             -fx-border-color: #E4E4E7;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 10 14;
                             -fx-font-size: 13px;
                             -fx-text-fill: #18181B;"/>
        </VBox>

    </VBox>

    <!-- Error label -->
    <Label fx:id="errorLabel"
           text=""
           wrapText="true"
           style="-fx-text-fill: #DC2626; -fx-font-size: 12px;">
        <VBox.margin><Insets top="12"/></VBox.margin>
    </Label>

    <Separator style="-fx-background-color: #E4E4E7;">
        <VBox.margin><Insets top="20" bottom="20"/></VBox.margin>
    </Separator>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="12">
        <Button text="Cancel"
                onAction="#handleCancel"
                style="-fx-background-color: transparent;
                       -fx-border-color: #E4E4E7;
                       -fx-border-radius: 8;
                       -fx-background-radius: 8;
                       -fx-text-fill: #52525B;
                       -fx-padding: 9 20;
                       -fx-font-size: 13px;
                       -fx-cursor: hand;"/>
        <Button text="Create Project"
                onAction="#handleSave"
                style="-fx-background-color: #00B37E;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-padding: 9 20;
                       -fx-font-size: 13px;
                       -fx-cursor: hand;"/>
    </HBox>

</VBox>