<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" style="-fx-background-color: #FFFFFF; -fx-padding: 24px;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.startupledgerpro.controller.QuotationGeneratorController">

    <children>
        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label fx:id="projectTitleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Quotation" />
                        <Label fx:id="projectIdLabel" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="Project ID:" />
                    </children>
                </VBox>
                <HBox HBox.hgrow="ALWAYS" />
                <Button text="Close" onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 20;" />
            </children>
        </HBox>

        <Separator />

        <TableView fx:id="quotationTableView" prefHeight="280.0" style="-fx-border-color: #E5E7EB; -fx-background-radius: 12;">
            <columns>
                <TableColumn fx:id="colDescription" prefWidth="240.0" text="Description" />
                <TableColumn fx:id="colFrequency" prefWidth="140.0" text="Frequency" />
                <TableColumn fx:id="colAmount" prefWidth="120.0" text="Amount" />
            </columns>
        </TableView>

        <HBox spacing="12.0">
            <children>
                <Button text="Add Line Item" onAction="#handleAddLineItem" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20;" />
                <Button text="Remove Selected" onAction="#handleRemoveSelectedItem" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20;" />
            </children>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <children>
                <Label fx:id="totalAmountLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Total: Tk 0.00" />
                <Button fx:id="savePdfButton" text="Export to PDF" onAction="#handleExportPdf" style="-fx-background-color: #00B37E; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20;" />
            </children>
        </HBox>
    </children>
</VBox>
