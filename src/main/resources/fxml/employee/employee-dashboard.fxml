<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1280.0" spacing="25.0" styleClass="light-root"
      stylesheets="@../../css/styles.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.startupledgerpro.controller.EmployeeDashboardController">

    <padding>
        <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT" styleClass="light-topbar" style="-fx-padding: 0 0 15 0;">
            <children>
                <VBox HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="welcomeLabel" style="-fx-text-fill: #18181B; -fx-font-size: 24px; -fx-font-weight: bold;" text="Welcome back, Engineer" />
                        <Label fx:id="emailLabel" style="-fx-text-fill: #71717A; -fx-font-size: 13px;" text="engineer@startupledger.pro" />
                    </children>
                </VBox>
                <Button onAction="#handleLogout" styleClass="btn-danger" text="🚪 Log Out" />
            </children>
        </HBox>

        <HBox spacing="20.0">
            <children>
                <VBox prefWidth="300.0" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label styleClass="stat-label" text="📋 ASSIGNED TASKS" />
                        <Label fx:id="assignedCountLabel" styleClass="stat-number" text="0" />
                    </children>
                </VBox>

                <VBox prefWidth="300.0" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label styleClass="stat-label" text="⚡ IN PROGRESS SPRINT TICKETS" />
                        <Label fx:id="inProgressCountLabel" styleClass="stat-number" style="-fx-text-fill: #00B37E;" text="0" />
                    </children>
                </VBox>

                <VBox prefWidth="300.0" spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label styleClass="stat-label" text="✅ COMPLETED MILESTONES" />
                        <Label fx:id="completedCountLabel" styleClass="stat-number" style="-fx-text-fill: #008E63;" text="0" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <VBox spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E4E4E7; -fx-padding: 20px;" VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="section-title" text="My Engineering Sprint Board" />
                                <Label styleClass="section-sub" text="Select an active row requirement ticket assignment to transition status lifecycles." />
                            </children>
                        </VBox>
                        <HBox spacing="10.0" alignment="CENTER_RIGHT">
                            <children>
                                <Button onAction="#handleMarkInProgress" styleClass="btn-outline" text="⚡ Start Progress" />
                                <Button onAction="#handleMarkDone" styleClass="btn-green" text="✅ Mark Completed" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="employeeTasksTableView" styleClass="light-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTaskId" prefWidth="120.0" text="Ticket Reference ID" />
                        <TableColumn fx:id="colTaskTitle" prefWidth="250.0" text="Task Requirement Title" />
                        <TableColumn fx:id="colProjectId" prefWidth="150.0" text="Mapped Project Context" />
                        <TableColumn fx:id="colTaskStatus" prefWidth="150.0" text="Current Execution State" />
                        <TableColumn fx:id="colDueDate" prefWidth="150.0" text="Target Due Date" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>